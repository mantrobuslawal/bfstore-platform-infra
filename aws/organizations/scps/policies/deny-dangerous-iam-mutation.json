{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyDangerousIAMMutationExceptApprovedRoles",
      "Effect": "Deny",
      "Action": [
        "iam:CreatePolicyVersion",
        "iam:SetDefaultPolicyVersion",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:UpdateAssumeRolePolicy",
        "iam:DeleteRolePermissionsBoundary",
        "iam:PutRolePermissionsBoundary",
        "iam:PassRole"
      ],
      "Resource": "*",
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/bfstore-*-github-iac-apply",
            "arn:aws:iam::*:role/bfstore-*-breakglass"
          ]
        }
      }
    }
  ]
}
